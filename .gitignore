# Fichiers à ignorer par Git

# Dépendances
/node_modules
/vendor

# Fichiers environnement
.env
.env.backup
.env.production

# Laravel
/public/hot
/public/storage
/storage/*.key
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
!storage/framework/cache/.gitkeep
!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep
!storage/logs/.gitkeep

# Cache et builds
/bootstrap/cache/*
!bootstrap/cache/.gitkeep
.phpunit.result.cache
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log

# IDE
/.idea
/.vscode
*.swp
*.swo
*~

# Système
.DS_Store
Thumbs.db

# Fichiers d'export
*.zip
export_*/
database_dump.sql

# Fichiers CSV de données (optionnel - décommenter si vous voulez les exclure)
# *.csv
